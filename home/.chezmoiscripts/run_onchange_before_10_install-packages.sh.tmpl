#!/bin/sh
set -e
printf "\033[0;32mInstalling packages\033[0m\n"

{{ $sudo := "sudo " -}}
{{ if eq .chezmoi.username "root" -}}
{{   $sudo = "" -}}
{{ end -}}

{{- /* Map packages may set scope = "personal" or "work" to limit install. Strings + maps without scope install on both. */ -}}
{{- $mt := .machine_type -}}

{{ if eq .chezmoi.os "darwin" -}}

# Bootstrap Homebrew if not installed
if ! command -v brew > /dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

HOMEBREW_NO_AUTO_UPDATE=1 brew install {{range .packages -}}
{{if kindIs "string" .}} "{{.}}" {{end -}}
{{if and (kindIs "map" .) (hasKey . "brew") (or (not (hasKey . "scope")) (eq (get . "scope") $mt))}} "{{get . "brew"}}" {{end -}}
{{- end}}

{{ $casks := list -}}
{{ range .packages -}}
{{   if and (kindIs "map" .) (hasKey . "cask") (or (not (hasKey . "scope")) (eq (get . "scope") $mt)) -}}
{{     $casks = append $casks (get . "cask") -}}
{{   end -}}
{{ end -}}
{{ if $casks -}}
HOMEBREW_NO_AUTO_UPDATE=1 brew install --cask {{ range $casks }}"{{.}}" {{ end }}
{{ end -}}

{{ else if eq .chezmoi.os "linux" -}}

{{$sudo}}pacman -S --needed --noconfirm {{range .packages -}}
{{if kindIs "string" .}} "{{.}}" {{end -}}
{{if and (kindIs "map" .) (hasKey . "pacman") (or (not (hasKey . "scope")) (eq (get . "scope") $mt))}} "{{get . "pacman"}}" {{end -}}
{{- end}}

yay -S --needed --noconfirm --answerdiff=None --answerclean=None {{range .packages -}}
{{if and (kindIs "map" .) (hasKey . "aur") (or (not (hasKey . "scope")) (eq (get . "scope") $mt))}} "{{get . "aur"}}" {{end -}}
{{- end}}

{{ else -}}

echo "Unknown OS"

{{ end -}}

# Change default shell to zsh if needed
if [ "$SHELL" != "/bin/zsh" ]; then
    if [ -t 0 ]; then
        printf "Change default shell to /bin/zsh? [y/N] "
        read -r answer
        case "$answer" in
            [yY])
                {{ if eq .chezmoi.os "linux" -}}
                # Ensure /bin/zsh is in /etc/shells
                grep -qx /bin/zsh /etc/shells || echo /bin/zsh | {{$sudo}}tee -a /etc/shells
                {{ end -}}
                chsh -s /bin/zsh
                ;;
        esac
    else
        echo "Skipping shell change (no interactive terminal)"
    fi
fi
